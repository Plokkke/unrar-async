{
  "name": "unrar-async",
  "version": "3.0.0",
  "description": "Async RAR archive extractor using Worker Threads and Streams. Powered by the official unrar C++ library compiled to WebAssembly.",
  "homepage": "https://github.com/plokkke/unrar-async",
  "bugs": {
    "url": "https://github.com/plokkke/unrar-async/issues"
  },
  "repository": "plokkke/unrar-async",
  "main": "./dist/index.js",
  "scripts": {
    "prepare": "husky install",
    "downloadUnrarSrc": "wget https://www.rarlab.com/rar/unrarsrc-6.1.7.tar.gz && tar -xf unrarsrc-6.1.7.tar.gz -C src/cpp && rm -rf unrarsrc-6.1.7.tar.gz && husky install",
    "clean": "rm -rf dist coverage dist_map",
    "clean:test": "rm -rf dist/test dist/build dist/**/*.map",
    "commit": "cz",
    "lint": "eslint './src/**/*.ts' --max-warnings 0",
    "tsc": "tsc",
    "build:debug": "tsc && node ./dist/build/make.js",
    "prebuild:release": "npm run lint",
    "build:release": "npm run clean && tsc && node ./dist/build/make.js release",
    "test": "mocha dist/test/*.spec.js",
    "test:debug": "npm run test -- --inspect-brk"
  },
  "keywords": [
    "unrar",
    "rar",
    "async",
    "stream",
    "wasm",
    "worker",
    "extract",
    "archive"
  ],
  "author": "Antoine Caron <antoine@crn-tech.fr>",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/eslint": "^8.56.6",
    "@types/mocha": "^10.0.6",
    "@types/shelljs": "^0.8.15",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "mocha": "^10.4.0",
    "prettier": "^3.2.5",
    "shelljs": "^0.8.5",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{json,md,less,yaml,yml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "files": [
    "dist",
    "*.md"
  ]
}
